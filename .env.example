# Copy this file to .env (or just export these yourself) if you want to override the defaults. Both are optional — settings.py picks sane values automatically if left unset.

# Where brands.json, checkpoint.json, listings/, and specs/ get written. Defaults to ./data
DATA_DIR=

# How many concurrent workers / identities to keep warm. Defaults to a guess based on CPU count and free RAM (capped at 50).
DEVICE_ADVISOR_WORKERS=
